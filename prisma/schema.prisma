  cost      Float
  currency  String @default("USD")
  context   String?
  userId    String?
  strategyId String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([context])
}

model McpApiKey {
  id        String   @id @default(cuid())
  name      String
  keyHash   String   @unique
  server    String
  permissions Json?
  isActive  Boolean  @default(true)
  lastUsedAt DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// SECONDARY MODELS (V2 completude)
// ============================================================================

model BrandOSConfig {
  id          String @id @default(cuid())
  strategyId  String @unique
  config      Json
  viewMode    String @default("EXECUTIVE")
  theme       Json?
  customFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignTemplate {
  id          String @id @default(cuid())
  name        String
  description String?
  category    String
  actionTypes Json
  budget      Float?
  currency    String @default("XAF")
  timeline    Json?
  channels    Json?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InterventionRequest {
  id          String @id @default(cuid())
  strategyId  String
  requesterId String
  type        String
  priority    String  @default("MEDIUM")
  title       String
  description String  @db.Text
  status      String  @default("OPEN")
  assigneeId  String?
  resolvedAt  DateTime?
  resolution  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([strategyId])
  @@index([status])
}

model CRMNote {
  id       String @id @default(cuid())
  dealId   String
  authorId String
  content  String @db.Text
  noteType String @default("GENERAL")

  createdAt DateTime @default(now())

  @@index([dealId])
}

model CRMActivity {
  id           String   @id @default(cuid())
  dealId       String
  activityType String
  description  String
  performedBy  String?
  performedAt  DateTime @default(now())
  metadata     Json?

  @@index([dealId])
}

model BoutiqueOrder {
  id         String @id @default(cuid())
  userId     String
  itemId     String
  quantity   Int    @default(1)
  amount     Float
  currency   String @default("XAF")
  status     String @default("PENDING")
  shippingAddress String?
  paidAt     DateTime?
  shippedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model EditorialComment {
  id        String @id @default(cuid())
  articleId String
  authorId  String
  content   String @db.Text
  parentId  String?

  createdAt DateTime @default(now())

  @@index([articleId])
}

model McpServerConfig {
  id          String  @id @default(cuid())
  serverName  String  @unique
  description String?
  isEnabled   Boolean @default(true)
  config      Json?
  healthUrl   String?
  lastHealthCheck DateTime?
  lastHealthStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GuildOrganizationMetric {
  id                  String @id @default(cuid())
  guildOrganizationId String
  period              String
  totalMissions       Int    @default(0)
  completedMissions   Int    @default(0)
  avgQcScore          Float  @default(0)
  firstPassRate       Float  @default(0)
  revenue             Float  @default(0)
  currency            String @default("XAF")
  measuredAt          DateTime @default(now())

  @@index([guildOrganizationId])
  @@index([period])
}

model NotificationPreference {
  id       String              @id @default(cuid())
  userId   String              @unique
  channels Json
  quiet    Json?
  digestFrequency String      @default("INSTANT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  link      String?
  isRead    Boolean             @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model WebhookConfig {
  id        String  @id @default(cuid())
  name      String
  url       String
  secret    String?
  events    Json
  isActive  Boolean @default(true)
  lastTriggeredAt DateTime?
  lastStatus Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FileUpload {
  id          String @id @default(cuid())
  uploaderId  String
  fileName    String
  fileUrl     String
  mimeType    String
  fileSize    Int
  entityType  String?
  entityId    String?
  pillarTags  Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([uploaderId])
}

model BadgeDefinition {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  iconUrl     String?
  category    String
  criteria    Json
  points      Int     @default(0)
  isActive    Boolean @default(true)

  awards UserBadge[]

  createdAt DateTime @default(now())
}

model UserBadge {
  id       String @id @default(cuid())
  userId   String
  badgeId  String
  awardedAt DateTime @default(now())
  metadata Json?

  badge BadgeDefinition @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

model MestorThread {
  id         String @id @default(cuid())
  userId     String
  context    String
  strategyId String?
  title      String?
  messageCount Int  @default(0)
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([strategyId])
}

model VariableStoreConfig {
  id         String @id @default(cuid())
  strategyId String @unique
  stalenessThresholdDays Int @default(30)
  propagationRules Json?
  autoRecalculate Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
